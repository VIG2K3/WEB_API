# OpenWeatherMap API key (used by backend)
OPENWEATHER_API_KEY=your_openweather_api_key

# MongoDB URL
MONGODB_URI=mongodb://localhost:27017/travelsmart

# Backend port
PORT=5000

# JWT secret 
JWT_SECRET=your_jwt_secret

# Geoapify Routing/Map API key
ROUTING_API_KEY=your_geoapify_routing_key

VITE_MAPTILES_KEY=your_maptiles_key
VITE_ROUTING_KEY=your_geoapify_routing_key
VITE_GEOCODING_KEY=your_geocoding_key

# Gmail password reset/notification App Password
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_gmail_app_password


# Chatbot API key
VITE_GROQ_API_KEY=your_groq_api_key

# OpenWeatherMap API key
VITE_OPENWEATHER_KEY=your_openweather_api_key
